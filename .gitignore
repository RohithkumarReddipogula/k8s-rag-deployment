# Docker Compose for local development
# Run: docker-compose up
# This runs the API without Kubernetes — useful for quick testing

version: "3.9"

services:
  rag-api:
    build: .
    ports:
      - "8000:8000"
    environment:
      - PYTHONUNBUFFERED=1
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 5s
    restart: unless-stopped
